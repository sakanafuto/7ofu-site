---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' });

// 記事の関連アプリ slug → 表示ラベル。未知の slug はそのまま出す
const appLabel = (slug?: string) =>
  slug ? ({ schemely: 'Schemely', koura: 'こうら日記', kamekoro: 'カメコロ' }[slug] ?? slug) : null;
---

<BaseLayout title="Blog | 7ofu" description="7ofu の技術メモ・開発ログ。iOS / Deep Link / 個人開発。">
  <section class="intro">
    <p class="crumb"><a href="/">Home</a> / Blog</p>
    <h1 class="title">Blog</h1>
    <p class="lead">つくったアプリの裏側や、iOS 開発でハマったことのメモ。</p>
  </section>

  {
    posts.length === 0 ? (
      <p>まだ記事がありません。</p>
    ) : (
      <ul class="postlist">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`}>
              <span class="postmeta">
                <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
                {appLabel(post.data.app) && <span class="badge">{appLabel(post.data.app)}</span>}
              </span>
              <strong>{post.data.title}</strong>
              <small>{post.data.description}</small>
            </a>
          </li>
        ))}
      </ul>
    )
  }

  <style>
    .crumb {
      font-size: 0.85rem;
      color: var(--muted);
    }
    .lead {
      color: var(--muted);
    }
    .postlist {
      list-style: none;
      margin: 2rem 0 0;
      padding: 0;
    }
    .postlist li + li {
      margin-top: 0.5rem;
    }
    .postlist a {
      display: block;
      padding: 1rem 1.15rem;
      border: 1px solid var(--line);
      border-radius: 0.75rem;
      text-decoration: none;
      color: var(--fg);
      background: color-mix(in srgb, var(--bg) 60%, white);
    }
    .postlist a:hover {
      border-color: var(--brand);
    }
    .postlist time {
      display: block;
      font-size: 0.78rem;
      color: var(--muted);
    }
    .postlist strong {
      display: block;
      margin: 0.15rem 0 0.3rem;
      color: var(--brand);
      font-size: 1.05rem;
    }
    .postlist small {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.6;
    }
    .postmeta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .badge {
      font-size: 0.7rem;
      font-weight: 600;
      color: var(--brand);
      background: color-mix(in srgb, var(--brand) 10%, white);
      border: 1px solid color-mix(in srgb, var(--brand) 25%, var(--line));
      border-radius: 999px;
      padding: 0.1rem 0.5rem;
    }
  </style>
</BaseLayout>
