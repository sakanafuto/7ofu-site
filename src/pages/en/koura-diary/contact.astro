---
import BaseLayout from '../../../layouts/BaseLayout.astro';

// Web3Forms access key（公開キー・秘密情報ではない）。ja フォームと同じ宛先に届く。
// 件名に (EN) を付けて英語フォーム由来を判別できるようにする。
const WEB3FORMS_ACCESS_KEY = '4d53d18b-45ea-4a8b-b261-fbf883ace717';
---

<BaseLayout
  title="Contact | Koura Diary"
  description="Contact, requests, and bug reports for Koura Diary"
>
  <section class="intro">
    <p class="crumb">
      <a href="/en/">Home</a> / <a href="/en/koura-diary">Koura Diary</a> / Contact
    </p>
    <h1>Contact</h1>
    <p class="lead">
      Requests, bug reports, and more — feel free to reach out.
    </p>
  </section>

  <form class="form" action="https://api.web3forms.com/submit" method="POST">
    <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
    <input type="hidden" name="subject" value="こうら日記 お問い合わせ (EN)" />
    <input type="hidden" name="from_name" value="Koura Diary site (EN)" />
    <input type="hidden" name="redirect" value="https://7ofu.dev/en/koura-diary/thanks" />
    {/* Honeypot for spam (invisible to humans) */}
    <input
      type="checkbox"
      name="botcheck"
      style="display:none"
      tabindex="-1"
      autocomplete="off"
    />

    <label>
      <span>Category</span>
      <select name="種別" required>
        <option value="Request">Request</option>
        <option value="Bug report">Bug report</option>
        <option value="Other">Other</option>
      </select>
    </label>

    <label>
      <span>Name (optional)</span>
      <input type="text" name="name" autocomplete="name" />
    </label>

    <label>
      <span>Email address</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
    </label>

    <label>
      <span>Message</span>
      <textarea
        name="message"
        rows="6"
        required
        placeholder="Please describe your request or question."></textarea>
    </label>

    <button type="submit" class="btn btn--primary">Send</button>
    <p class="note">
      Your message is delivered to the developer by email. Your email address is used only to reply.
    </p>
  </form>

  <style>
    .intro { margin-bottom: 2rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .lead { color: var(--muted); }

    .form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 34rem;
    }
    .form label {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      font-size: 0.95rem;
    }
    .form label > span { font-weight: 600; }
    .form input,
    .form select,
    .form textarea {
      font: inherit;
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: white;
      color: var(--fg);
    }
    .form input:focus,
    .form select:focus,
    .form textarea:focus {
      outline: none;
      border-color: var(--brand);
    }
    .form textarea { resize: vertical; }
    .form small { color: var(--muted); font-size: 0.82rem; }
    .form .note {
      margin: 0;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .btn {
      align-self: flex-start;
      display: inline-block;
      padding: 0.7rem 1.5rem;
      border-radius: 10px;
      border: 1px solid var(--brand);
      color: white;
      background: var(--brand);
      text-decoration: none;
      font-size: 0.95rem;
      cursor: pointer;
      transition: opacity 0.15s ease;
    }
    .btn:hover { opacity: 0.88; }
  </style>
</BaseLayout>
