---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const docs = [
  { href: '/en/koura-diary/terms', title: 'Terms of Use', desc: 'Conditions for using the app' },
  { href: '/en/koura-diary/privacy', title: 'Privacy Policy', desc: 'How your information is handled' },
  { href: '/en/koura-diary/account-deletion', title: 'Account & Data Deletion', desc: 'How to delete your account and data' },
  { href: '/en/koura-diary/disclaimer', title: 'Disclaimer', desc: 'About health and nutrition information' },
];
---

<BaseLayout title="Koura Diary | 7ofu" description="Koura Diary help and legal pages">
  <section class="intro">
    <p class="crumb"><a href="/en/">Home</a> / Koura Diary</p>
    <h1 class="title">
      <img src="/koura-diary.svg" alt="" width="40" height="40" />
      Koura Diary
    </h1>
    <p class="lead">A gentle daily care-log app for your tortoise.</p>
    <p class="social">
      <a
        class="social-link"
        href="https://x.com/KouraDiary"
        target="_blank"
        rel="noopener"
        aria-label="Koura Diary on X (formerly Twitter)"
      >
        <svg
          class="social-link__icon"
          viewBox="0 0 24 24"
          width="1em"
          height="1em"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
        <span>@KouraDiary on X</span>
      </a>
    </p>
  </section>

  <section>
    <h2>Download</h2>
    <div class="stores">
      <a
        class="store store--live"
        href="https://apps.apple.com/app/id6783813983"
        target="_blank"
        rel="noopener"
      >
        <span class="store__os">iOS</span>
        <strong class="store__state">Get it on the App Store ↗</strong>
        <small>For iPhone / iPad.</small>
      </a>
    </div>
  </section>

  <section>
    <h2>How to use</h2>
    <ul class="doclist">
      <li>
        <a href="/en/koura-diary/help">
          <strong>How to use / Help</strong>
          <small>Recording, family sharing, backup, and more</small>
        </a>
      </li>
    </ul>
  </section>

  <section>
    <h2>Terms &amp; Policies</h2>
    <ul class="doclist">
      {docs.map((d) => (
        <li>
          <a href={d.href}>
            <strong>{d.title}</strong>
            <small>{d.desc}</small>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .intro { margin-bottom: 1rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .title { display: flex; align-items: center; gap: 0.65rem; }
    .lead { color: var(--muted); }
    .social { margin-top: 0.85rem; }
    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.85rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      font-size: 0.88rem;
      color: var(--fg);
      text-decoration: none;
      transition: border-color 0.15s ease, color 0.15s ease;
    }
    .social-link:hover { border-color: var(--brand); color: var(--brand); }
    .social-link__icon { flex-shrink: 0; }
    .doclist {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }
    .doclist a {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding: 1.15rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
      text-decoration: none;
      color: var(--fg);
      transition: border-color 0.15s ease;
    }
    .doclist a:hover { border-color: var(--brand); }
    .doclist small { color: var(--muted); }

    .stores {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      max-width: 22rem;
    }
    .store {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 1.25rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
    }
    a.store {
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s ease;
    }
    a.store:hover { border-color: var(--brand); }
    .store--live { border-color: var(--brand); }
    .store__os {
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.06em;
    }
    .store__state { font-size: 1.05rem; }
    .store small { color: var(--muted); }
  </style>
</BaseLayout>
