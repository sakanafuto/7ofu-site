---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const docs = [
  { href: '/en/kamekoro/terms', title: 'Terms of Use', desc: 'Conditions for using the app' },
  { href: '/en/kamekoro/privacy', title: 'Privacy Policy', desc: 'How your data is handled' },
];
---

<BaseLayout title="Kamekoro | 7ofu" description="Kamekoro terms, policies, and contact">
  <section class="intro">
    <p class="crumb"><a href="/en/">Home</a> / Kamekoro</p>
    <h1 class="title">
      <img src="/kamekoro.png" alt="" width="40" height="40" />
      Kamekoro
    </h1>
    <p class="lead">
      A cute reptile-feeding physics puzzle game. Play offline, or compete with
      scores from around the world on the leaderboard.
    </p>
  </section>

  <section>
    <h2>Download</h2>
    <div class="stores">
      <a
        class="store store--live"
        href="https://apps.apple.com/jp/app/%E3%82%AB%E3%83%A1%E3%82%B3%E3%83%AD/id6789081791"
        target="_blank"
        rel="noopener"
      >
        <span class="store__os">iOS</span>
        <strong class="store__state">Get it on the App Store ↗</strong>
        <small>For iPhone.</small>
      </a>
    </div>
  </section>

  <section>
    <h2>Terms &amp; Policies</h2>
    <ul class="doclist">
      {docs.map((d) => (
        <li>
          <a href={d.href}>
            <strong>{d.title}</strong>
            <small>{d.desc}</small>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section>
    <h2>Contact</h2>
    <ul class="doclist">
      <li>
        <a href="/en/kamekoro/contact">
          <strong>Contact form</strong>
          <small>Requests, bug reports, reporting a nickname, and more</small>
        </a>
      </li>
    </ul>
  </section>

  <style>
    .intro { margin-bottom: 1rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .title { display: flex; align-items: center; gap: 0.65rem; }
    .title img { border-radius: 9px; }
    .lead { color: var(--muted); line-height: 1.75; }
    .doclist {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }
    .doclist a {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding: 1.15rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
      text-decoration: none;
      color: var(--fg);
      transition: border-color 0.15s ease;
    }
    .doclist a:hover { border-color: var(--brand); }
    .doclist small { color: var(--muted); }

    .stores {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(14rem, 20rem));
      gap: 1rem;
    }
    .store {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 1.25rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
    }
    a.store {
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s ease;
    }
    a.store:hover { border-color: var(--brand); }
    .store--live { border-color: var(--brand); }
    .store__os {
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.06em;
    }
    .store__state { font-size: 1.05rem; }
    .store small { color: var(--muted); }
  </style>
</BaseLayout>
