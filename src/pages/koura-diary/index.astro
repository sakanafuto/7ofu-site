---
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = [
  { href: '/koura-diary/terms', title: '利用規約', desc: 'アプリの利用条件' },
  { href: '/koura-diary/privacy', title: 'プライバシーポリシー', desc: '情報の取扱い' },
  { href: '/koura-diary/account-deletion', title: 'アカウントとデータの削除', desc: 'アカウント・データの削除方法' },
  { href: '/koura-diary/disclaimer', title: '免責事項', desc: '健康・栄養表示について' },
];
---

<BaseLayout title="こうら日記 | 7ofu" description="こうら日記のヘルプ・規約">
  <section class="intro">
    <p class="crumb"><a href="/">Home</a> / こうら日記</p>
    <h1 class="title">
      <img src="/koura-diary.svg" alt="" width="40" height="40" />
      こうら日記
    </h1>
    <p class="lead">リクガメの毎日を、やさしく記録する飼育日記アプリ。</p>
    <p class="social">
      <a
        class="social-link"
        href="https://x.com/KouraDiary"
        target="_blank"
        rel="noopener"
        aria-label="こうら日記の公式X（旧Twitter）"
      >
        <svg
          class="social-link__icon"
          viewBox="0 0 24 24"
          width="1em"
          height="1em"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
          ></path>
        </svg>
        <span>公式X @KouraDiary</span>
      </a>
    </p>
  </section>

  <section>
    <h2>ダウンロード</h2>
    <div class="stores">
      <a
        class="store store--live"
        href="https://apps.apple.com/app/id6783813983"
        target="_blank"
        rel="noopener"
      >
        <span class="store__os">iOS</span>
        <strong class="store__state">App Store で入手 ↗</strong>
        <small>iPhone / iPad に対応。</small>
      </a>
    </div>
  </section>

  <section>
    <h2>使い方</h2>
    <ul class="doclist">
      <li>
        <a href="/koura-diary/help">
          <strong>使い方・ヘルプ</strong>
          <small>記録の付け方、家族との共有、バックアップ など</small>
        </a>
      </li>
    </ul>
  </section>

  <section>
    <h2>規約・ポリシー</h2>
    <ul class="doclist">
      {docs.map((d) => (
        <li>
          <a href={d.href}>
            <strong>{d.title}</strong>
            <small>{d.desc}</small>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .intro { margin-bottom: 1rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .title { display: flex; align-items: center; gap: 0.65rem; }
    .lead { color: var(--muted); }
    .social { margin-top: 0.85rem; }
    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.85rem;
      border: 1px solid var(--line);
      border-radius: 999px;
      font-size: 0.88rem;
      color: var(--fg);
      text-decoration: none;
      transition: border-color 0.15s ease, color 0.15s ease;
    }
    .social-link:hover { border-color: var(--brand); color: var(--brand); }
    .social-link__icon { flex-shrink: 0; }
    .doclist {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }
    .doclist a {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding: 1.15rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
      text-decoration: none;
      color: var(--fg);
      transition: border-color 0.15s ease;
    }
    .doclist a:hover { border-color: var(--brand); }
    .doclist small { color: var(--muted); }

    .stores {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
      max-width: 22rem;
    }
    .store {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 1.25rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
    }
    a.store {
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s ease;
    }
    a.store:hover { border-color: var(--brand); }
    .store--live { border-color: var(--brand); }
    .store__os {
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.06em;
    }
    .store__state { font-size: 1.05rem; }
    .store small { color: var(--muted); }
  </style>
</BaseLayout>
