---
import BaseLayout from '../../layouts/BaseLayout.astro';
const docs = [
  { href: '/koura-diary/terms', title: '利用規約', desc: 'アプリの利用条件' },
  { href: '/koura-diary/privacy', title: 'プライバシーポリシー', desc: '情報の取扱い' },
  { href: '/koura-diary/account-deletion', title: 'アカウントとデータの削除', desc: 'アカウント・データの削除方法' },
  { href: '/koura-diary/disclaimer', title: '免責事項', desc: '健康・栄養表示について' },
];
---

<BaseLayout title="こうら日記 | 7ofu" description="こうら日記のヘルプ・規約">
  <section class="intro">
    <p class="crumb"><a href="/">Home</a> / こうら日記</p>
    <h1 class="title">
      <img src="/koura-diary.svg" alt="" width="40" height="40" />
      こうら日記
    </h1>
    <p class="lead">リクガメの毎日を、やさしく記録する飼育日記アプリ。</p>
  </section>

  <section>
    <h2>ダウンロード</h2>
    <div class="stores">
      <a
        class="store store--live"
        href="https://apps.apple.com/app/id6783813983"
        target="_blank"
        rel="noopener"
      >
        <span class="store__os">iOS</span>
        <strong class="store__state">App Store で入手 ↗</strong>
        <small>iPhone / iPad に対応。</small>
      </a>
      <div class="store store--wip">
        <span class="store__os">Android</span>
        <strong class="store__state">🚧 開発中</strong>
        <small>Google Play 版を準備しています。</small>
      </div>
    </div>
    <div class="recruit">
      <p>
        <strong>Android 版のテスターを募集しています。</strong>
        Google Play の公開にはテスターの協力（クローズドテスト）が必要です。
        ご協力いただける方は、ぜひひとことお寄せください。
      </p>
      <div class="recruit__actions">
        <a class="btn btn--primary" href="/koura-diary/contact?type=tester">
          テスターに応募する
        </a>
        <a class="btn" href="/koura-diary/contact?type=request">
          Android 版がほしいと要望を送る
        </a>
      </div>
      <p class="recruit__note">
        ※ お申し込み後すぐにテストを開始できるわけではありません。準備が整い次第、
        いただいたメールアドレス宛に個別でご案内させていただく場合があります。
      </p>
    </div>
  </section>

  <section>
    <h2>使い方</h2>
    <ul class="doclist">
      <li>
        <a href="/koura-diary/help">
          <strong>使い方・ヘルプ</strong>
          <small>記録の付け方、家族との共有、バックアップ など</small>
        </a>
      </li>
    </ul>
  </section>

  <section>
    <h2>規約・ポリシー</h2>
    <ul class="doclist">
      {docs.map((d) => (
        <li>
          <a href={d.href}>
            <strong>{d.title}</strong>
            <small>{d.desc}</small>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <style>
    .intro { margin-bottom: 1rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .title { display: flex; align-items: center; gap: 0.65rem; }
    .lead { color: var(--muted); }
    .doclist {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }
    .doclist a {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding: 1.15rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
      text-decoration: none;
      color: var(--fg);
      transition: border-color 0.15s ease;
    }
    .doclist a:hover { border-color: var(--brand); }
    .doclist small { color: var(--muted); }

    .stores {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
    @media (max-width: 480px) {
      .stores { grid-template-columns: 1fr; }
    }
    .store {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
      padding: 1.25rem 1.35rem;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: white;
    }
    .store--wip { background: #f7f4ec; }
    a.store {
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s ease;
    }
    a.store:hover { border-color: var(--brand); }
    .store--live { border-color: var(--brand); }
    .store__os {
      font-size: 0.8rem;
      color: var(--muted);
      letter-spacing: 0.06em;
    }
    .store__state { font-size: 1.05rem; }
    .store small { color: var(--muted); }

    .recruit {
      margin-top: 1.25rem;
      padding: 1.25rem 1.35rem;
      border: 1px solid var(--line);
      border-left: 3px solid var(--brand);
      border-radius: 14px;
      background: #fbfaf5;
    }
    .recruit p { margin: 0 0 0.95rem; line-height: 1.75; }
    .recruit__note {
      margin: 0.95rem 0 0;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.7;
    }
    .recruit__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
    }
    .btn {
      display: inline-block;
      padding: 0.6rem 1.1rem;
      border-radius: 10px;
      border: 1px solid var(--brand);
      color: var(--brand);
      background: white;
      text-decoration: none;
      font-size: 0.92rem;
      transition: background 0.15s ease, color 0.15s ease, opacity 0.15s ease;
    }
    .btn:hover { background: var(--brand); color: white; }
    .btn--primary { background: var(--brand); color: white; }
    .btn--primary:hover { opacity: 0.88; }
  </style>
</BaseLayout>
