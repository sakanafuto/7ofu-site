---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Web3Forms のアクセスキー（クライアント埋め込み前提の公開キー・秘密情報ではない）。
// 他アプリと同じ宛先に届く。分けたい場合はカメコロ用のキーに差し替える。
const WEB3FORMS_ACCESS_KEY = '4d53d18b-45ea-4a8b-b261-fbf883ace717';
---

<BaseLayout
  title="お問い合わせ | カメコロ"
  description="カメコロへのお問い合わせ・要望・不具合報告・ニックネームの通報"
>
  <section class="intro">
    <p class="crumb">
      <a href="/">Home</a> / <a href="/kamekoro">カメコロ</a> / お問い合わせ
    </p>
    <h1>お問い合わせ</h1>
    <p class="lead">
      ご要望・不具合の報告のほか、ランキングに表示される不適切なニックネームの通報も
      こちらからどうぞ。
    </p>
  </section>

  <form class="form" action="https://api.web3forms.com/submit" method="POST">
    <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
    <input type="hidden" name="subject" value="カメコロ お問い合わせ" />
    <input type="hidden" name="from_name" value="カメコロ サイト" />
    <input type="hidden" name="redirect" value="https://7ofu.dev/kamekoro/thanks" />
    {/* スパム対策のハニーポット（人には見えない） */}
    <input
      type="checkbox"
      name="botcheck"
      style="display:none"
      tabindex="-1"
      autocomplete="off"
    />

    <label>
      <span>種別</span>
      <select name="種別" required>
        <option value="要望・リクエスト">要望・リクエスト</option>
        <option value="不具合報告">不具合の報告</option>
        <option value="ニックネーム通報">ニックネームの通報</option>
        <option value="その他">その他のお問い合わせ</option>
      </select>
    </label>

    <label>
      <span>お名前（任意）</span>
      <input type="text" name="name" autocomplete="name" />
    </label>

    <label>
      <span>メールアドレス</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
      <small>返信が必要な場合の宛先に使用します。</small>
    </label>

    <label>
      <span>内容</span>
      <textarea
        name="message"
        rows="6"
        required
        placeholder="ご要望・お問い合わせ内容をご記入ください。ニックネームの通報の場合は、対象の表示名やおおよそのスコア・日時をお知らせいただけると特定に役立ちます。"></textarea>
    </label>

    <button type="submit" class="btn btn--primary">送信する</button>
    <p class="note">
      送信内容は運営者にメールで届きます。いただいたメールアドレスは、返信の目的にのみ使用します。
    </p>
  </form>

  <script is:inline>
    // アプリ内の通報・問い合わせ導線から ?type= を受けて種別を初期選択する
    // （koura-diary の contact と同じパターン・kamekoro Issue #33）。
    // ?nickname= があれば通報対象を本文へ事前入力する（ユーザーが上書き可能）。
    const params = new URLSearchParams(location.search);
    const t = params.get('type');
    const map = {
      'report-nickname': 'ニックネーム通報',
      bug: '不具合報告',
      request: '要望・リクエスト',
    };
    const sel = document.querySelector('select[name="種別"]');
    if (t && sel && map[t]) sel.value = map[t];
    const nickname = params.get('nickname');
    const msg = document.querySelector('textarea[name="message"]');
    if (nickname && msg && !msg.value) {
      msg.value = '通報対象のニックネーム: ' + nickname + '\n';
    }
  </script>

  <style>
    .intro { margin-bottom: 2rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .lead { color: var(--muted); }

    .form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
      max-width: 34rem;
    }
    .form label {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      font-size: 0.95rem;
    }
    .form label > span { font-weight: 600; }
    .form input,
    .form select,
    .form textarea {
      font: inherit;
      padding: 0.7rem 0.85rem;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: white;
      color: var(--fg);
    }
    .form input:focus,
    .form select:focus,
    .form textarea:focus {
      outline: none;
      border-color: var(--brand);
    }
    .form textarea { resize: vertical; }
    .form small { color: var(--muted); font-size: 0.82rem; }
    .form .note {
      margin: 0;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .btn {
      align-self: flex-start;
      display: inline-block;
      padding: 0.7rem 1.5rem;
      border-radius: 10px;
      border: 1px solid var(--brand);
      color: white;
      background: var(--brand);
      text-decoration: none;
      font-size: 0.95rem;
      cursor: pointer;
      transition: opacity 0.15s ease;
    }
    .btn:hover { opacity: 0.88; }
  </style>
</BaseLayout>
