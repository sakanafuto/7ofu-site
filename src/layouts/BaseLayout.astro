---
import {
  getLangFromUrl,
  useTranslations,
  localizePath,
  alternatePath,
  languageShort,
  switchLangLabel,
} from '../i18n/ui';

export interface Props {
  title: string;
  description?: string;
}
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { title, description = t('meta.siteDescription') } = Astro.props;

const nav = [
  { href: localizePath('/', lang), label: t('nav.home') },
  { href: localizePath('/koura-diary/', lang), label: t('nav.koura') },
  { href: localizePath('/schemely/', lang), label: t('nav.schemely') },
  { href: localizePath('/kamekoro/', lang), label: t('nav.kamekoro') },
  // ブログは ja のみ。en 記事が出たら en ナビにも出す
  ...(lang === 'ja' ? [{ href: '/blog/', label: t('nav.blog') }] : []),
];
const otherLang = lang === 'ja' ? 'en' : 'ja';
const switchHref = alternatePath(Astro.url.pathname, otherLang);
// hreflang 用の絶対 URL（Astro.site = https://7ofu.dev）。
const jaHref = new URL(alternatePath(Astro.url.pathname, 'ja'), Astro.site).href;
const enHref = new URL(alternatePath(Astro.url.pathname, 'en'), Astro.site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="alternate" hreflang="ja" href={jaHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={jaHref} />
    <title>{title}</title>
    <!-- Lism CSS（デザインフレームワーク・#75）。デザイントークン/タイポグラフィのベース。 -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/lism-css@0/dist/css/main.css"
    />
    <style is:global>
      :root {
        --site-max: 44rem;
        --brand: #41592d;
        --bg: #fbf7ee;
        --fg: #2c2c2c;
        --muted: #6b6b6b;
        --line: #e6e0d3;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--fg);
        font-family:
          system-ui, -apple-system, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
        line-height: 1.8;
      }
      .container {
        max-width: var(--site-max);
        margin-inline: auto;
        padding-inline: 1.5rem;
      }
      .site-header {
        border-bottom: 1px solid var(--line);
        background: color-mix(in srgb, var(--bg) 80%, white);
        position: sticky;
        top: 0;
        backdrop-filter: blur(6px);
      }
      .site-header .container {
        display: flex;
        align-items: center;
        gap: 0.6rem 1.25rem;
        min-height: 3.5rem;
      }
      .brand {
        font-weight: 700;
        color: var(--brand);
        text-decoration: none;
        font-size: 1.05rem;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .site-nav {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        margin-inline-start: auto;
      }
      .site-nav a {
        color: var(--fg);
        text-decoration: none;
        font-size: 0.95rem;
        white-space: nowrap;
      }
      .site-nav a:hover { color: var(--brand); }
      .lang-switch {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 0.2rem 0.65rem;
        font-size: 0.82rem;
        color: var(--muted);
        text-decoration: none;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .lang-switch__icon { opacity: 0.85; }
      .lang-switch:hover { border-color: var(--brand); color: var(--brand); }

      /* モバイルは 2 段ヘッダー: 1 段目=ロゴ+言語トグル / 2 段目=nav をセンタリング。 */
      @media (max-width: 40rem) {
        .site-header .container {
          flex-wrap: wrap;
          padding-block: 0.55rem;
          min-height: 0;
        }
        .site-nav {
          order: 1;
          flex-basis: 100%;
          justify-content: center;
          gap: 1.25rem;
          margin-inline-start: 0;
        }
        .lang-switch { margin-inline-start: auto; }
      }
      main { padding-block: 4rem 6rem; }
      p { margin-block: 1.1rem; }
      .site-footer {
        border-top: 1px solid var(--line);
        color: var(--muted);
        font-size: 0.85rem;
      }
      .site-footer .container { padding-block: 1.5rem; }
      a { color: var(--brand); }
      h1 { font-size: 1.7rem; line-height: 1.45; margin: 0 0 1rem; }
      h2 {
        font-size: 1.2rem;
        line-height: 1.5;
        margin: 3.25rem 0 1.5rem;
        border-left: 4px solid var(--brand);
        padding-left: 0.7rem;
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href={localizePath('/', lang)} class="brand">7ofu</a>
        <nav class="site-nav">
          {nav.map((n) => <a href={n.href}>{n.label}</a>)}
        </nav>
        <a
          class="lang-switch"
          href={switchHref}
          hreflang={otherLang}
          rel="alternate"
          aria-label={switchLangLabel[lang]}
        >
          <svg
            class="lang-switch__icon"
            viewBox="0 0 24 24"
            width="1em"
            height="1em"
            fill="none"
            stroke="currentColor"
            stroke-width="1.6"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="9" />
            <path d="M3 12h18" />
            <path d="M12 3c2.6 2.5 4 5.6 4 9s-1.4 6.5-4 9c-2.6-2.5-4-5.6-4-9s1.4-6.5 4-9z" />
          </svg>
          <span>{languageShort[otherLang]}</span>
        </a>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="container">© 2026 7ofu</div>
    </footer>
  </body>
</html>
