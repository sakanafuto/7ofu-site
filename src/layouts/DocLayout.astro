---
// .md ページの frontmatter から `layout: ../../layouts/DocLayout.astro` で使う。
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const { frontmatter } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
// アプリ名とハブへのパス。frontmatter で上書き可（未指定はこうら日記＝従来の既定）。
const app = frontmatter.app ?? 'こうら日記';
const hub = frontmatter.hub ?? '/koura-diary/';
// YAML の日付は Date になりうるので YYYY-MM-DD に整形。
const updated = frontmatter.updated
  ? String(frontmatter.updated).slice(0, 10)
  : null;
---

<BaseLayout
  title={`${frontmatter.title} | ${app}`}
  description={frontmatter.title}
>
  <article class="doc">
    <p class="crumb"><a href={hub}>{app}</a> / {frontmatter.title}</p>
    <h1>{frontmatter.title}</h1>
    {updated && <p class="updated">{t('doc.updated')} {updated}</p>}
    <div class="body"><slot /></div>
    <p class="back">
      <a href={hub}>{t('doc.back').replace('{app}', app)}</a>
    </p>
  </article>
  <style>
    .doc { max-width: 40rem; }
    .crumb { font-size: 0.85rem; color: var(--muted); margin-bottom: 1rem; }
    .updated {
      color: var(--muted);
      font-size: 0.85rem;
      margin: -0.5rem 0 2.75rem;
    }
    .body :global(ol),
    .body :global(ul) { padding-left: 1.4rem; }
    .body :global(li) { margin-block: 0.5rem; }
    .body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
      margin-block: 1.5rem;
    }
    .body :global(th),
    .body :global(td) {
      border: 1px solid var(--line);
      padding: 0.55rem 0.7rem;
      text-align: left;
      vertical-align: top;
      overflow-wrap: break-word;
    }
    .body :global(th) { background: #f2eee3; font-weight: 600; }
    /* 3 列表は狭い画面で横スクロールに逃がす。 */
    @media (max-width: 34rem) {
      .body :global(table) { display: block; overflow-x: auto; }
    }
    .back {
      margin-top: 4rem;
      padding-top: 1.75rem;
      border-top: 1px solid var(--line);
      font-size: 0.9rem;
    }
  </style>
</BaseLayout>
